<?xml version="1.0" encoding="utf-8"?>
<Mod id="{{modGuid}}" version="1">
  <Properties>
    <Name>{{xml.metadata.modName}}</Name>
    <Description>Generated custom leader and civilization mod scaffold.</Description>
    <Teaser>{{xml.leader.name}} leads {{xml.civilization.name}}.</Teaser>
    <Authors>{{xml.metadata.author}}</Authors>
    <AffectsSavedGames>1</AffectsSavedGames>
    <CompatibleVersions>1.2,2.0</CompatibleVersions>
  </Properties>
  <Files>
    <File>Data/Civilization.sql</File>
    <File>Data/Leader.sql</File>
    <File>Data/Traits.sql</File>
    <File>Data/Agenda.sql</File>
    <File>Data/Colors.sql</File>
    <File>Text/LocalizedText_en_US.sql</File>
    <File>Text/LocalizedText_zh_Hans.sql</File>
  </Files>
  <Components>
    <UpdateDatabase id="{{prefix}}_Data">
      <Items>
        <File>Data/Civilization.sql</File>
        <File>Data/Leader.sql</File>
        <File>Data/Traits.sql</File>
        <File>Data/Agenda.sql</File>
        <File>Data/Colors.sql</File>
      </Items>
    </UpdateDatabase>
    <LocalizedText id="{{prefix}}_Text">
      <Items>
        <File>Text/LocalizedText_en_US.sql</File>
        <File>Text/LocalizedText_zh_Hans.sql</File>
      </Items>
    </LocalizedText>
  </Components>
</Mod>
